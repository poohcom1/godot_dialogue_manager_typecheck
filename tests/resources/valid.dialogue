using DialogueAutoload

~ start

Info: Starting valid dialogue.

# Built-ins / literals
do wait(0.1)
do debug("Hello")
do debug(true)
do debug(Vector2(0, 0))
do debug(Vector2(0, 0), true, "hello")
do debug()
# Base
do test_global()
do test_using()
do Autoload.test_autoload()
# Arg
do test_args_typed(1, 2, Vector2(1, 1))
# Nested expressions
do debug(test_global())
# Enums
do GlobalEnum
do GlobalEnum.A
do Autoload.Enum
do Autoload.Enum.A
# Constants
do Autoload.static_member
do Autoload.static_member.global_position
do Autoload.TestConstant
do Autoload.SubClass
do Autoload.SubClass.SubConstant
do Autoload.SubClass.static_func()
do Autoload.get_parent()
do Autoload.node2d.global_position
# C#
do CSharpAutoload.Function()

# Ignore comment

# @type_ignore
do unknown_func()

Info: Finished valid dialogue.

do get_tree().quit()

=> END
