using DialogueAutoload


~ start
do unknown_func() # Unknown func for global
do Autoload.unknown_func() # Unknown func for autoload
do Autoload.unknown_member # Unknown member for autoload
do Autoload.Enum.AB # Unknown enum
do Autoload.SubClass.instance_member # Access instance member from static
do Autoload.SubClass.instance_func() # Access to instance func from static
do debug(unknown_func()) # Unknown inner arg
do test_args(test_global(), unknown_func()) # Unkown 2nd inner arg
do test_args_typed(12) # count mismatch
do test_args_typed("12", "12", Vector2(0, 0))
do test_args_typed(12, 12, Vector2(0, 0))
do test_args_typed(12, "12", 12)
do CSharpAutoload.UnknownFunction() # C# test
# Subscript
do debug(Autoload.arr_var["Hello"])
do debug(Autoload.node2d[12])
=> END
